# molecular dynamics

sim_type = MD

dt = 0.001
thermostat = bussi
bussi_tau = 1000
newtonian_steps = 1 # use 1 if you want the thermostat to act every step: 

steps = 1e4 
          
interaction_type = RNA2
salt_concentration = 1.0
  
max_backbone_force = 5
max_backbone_force_far = 10
external_forces = true
external_forces_file = ../init_force.txt

T = 25C 
backend = CPU
verlet_skin = 0.05
delta_translation = 1.3e-7
restart_step_counter = 1
energy_file = energyMDekvi.dat
print_energy_every = $(steps)
print_conf_interval = $(steps)
time_scale = linear
refresh_vel = true

mismatch_repulsion = true
use_average_seq = false 
seq_dep_file = /u/p/ppokorna/progs/oxDNA/rna_sequence_dependent_parameters.txt


