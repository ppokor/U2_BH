####  PROGRAM PARAMETERS  ####
backend = CPU
#debug = 1
seed = 129382

####    SIM PARAMETERS    ####
steps = 25000000
newtonian_steps = 103
diff_coeff = 2.50
#pt = 0.1
thermostat = john

T = 25C 
dt = 0.001
verlet_skin = 0.05

interaction_type = RNA2
salt_concentration = 1.0

####    INPUT / OUTPUT    ####
topology = ./output.top
conf_file = ./output.dat
trajectory_file = trajectory.dat
refresh_vel = 1
log_file = log.dat
no_stdout_energy = 1
restart_step_counter = 1
energy_file = energy.dat
print_conf_interval = 5e3
print_energy_every = $steps
time_scale = linear
external_forces = 0

data_output_1 = {
    name = split_energy.dat
    print_every = 1
    col_1 = {
        type = potential_energy
        split = true
    }
}


mismatch_repulsion = true
use_average_seq = false 
seq_dep_file = /u/p/ppokorna/progs/oxDNA/rna_sequence_dependent_parameters.txt



# other - dont abort if it generetes more than 1 MB/s of data 
max_io=2.0
